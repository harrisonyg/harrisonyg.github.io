# Copy to ".env" in this same folder (project root). Never commit .env.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional — comma-separated, exact redirect URIs the proxy may exchange codes for:
# SPOTIFY_REDIRECT_ALLOWLIST=https://harrisonyg.github.io/,http://127.0.0.1:3000/index.html

# Optional — local proxy port (default 3847):
# SPOTIFY_PROXY_PORT=3847
